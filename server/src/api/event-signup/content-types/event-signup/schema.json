{
  "kind": "collectionType",
  "collectionName": "event_signups",
  "info": {
    "singularName": "event-signup",
    "pluralName": "event-signups",
    "displayName": "Event Signup"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "telephone": {
      "type": "string"
    },
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event",
      "inversedBy": "eventSignups"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "isPaid": {
      "type": "boolean",
      "default": false
    }
  }
}
